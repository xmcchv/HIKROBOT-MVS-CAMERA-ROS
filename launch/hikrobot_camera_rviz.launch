<launch>
    <!-- 相机内参 -->
    <rosparam file="$(find hikmvs_ros_driver)/config/calibration.yaml" command="load" />
    <!-- hikrobot mvs camera 参数 -->
    <rosparam file="$(find hikmvs_ros_driver)/config/camera.yaml" command="load" />
    <!-- 相机ros参数 -->
    <rosparam file="$(find hikrobot_camera)/config/setup_ros.yaml" command="load"/>
    <node pkg="hikmvs_ros_driver" type="hikmvs_ros_driver" name="hikmvs_ros_driver" respawn="true" output="screen" />
    <!-- 
    pkg指出ROS应该运行哪个pkg
    type是可执行文件的名称
    name则是可以任意给出的，它覆盖了原文件中ros::init指定的node的名字 
    -->
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find hikmvs_ros_driver)/rviz_config/hikrobot.rviz" />

</launch>
